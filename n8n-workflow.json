{
  "name": "Self-Healing-CI-HACKATHON-GOD-MODE",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "self-heal",
        "options": {}
      },
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "webhookId": "self-heal-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.all()[0].json.body;\nreturn {\n  owner: body.repository.split('/')[0],\n  repo: body.repository.split('/')[1],\n  branch: body.branch,\n  path: body.file_to_fix\n};"
      },
      "id": "2",
      "name": "Parse_Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [200, 0]
    },
    {
      "parameters": {
        "resource": "file",
        "operation": "get",
        "owner": "={{$json.owner}}",
        "repository": "={{$json.repo}}",
        "filePath": "={{$json.path}}",
        "reference": "={{$json.branch}}"
      },
      "id": "3",
      "name": "Get_Original_File",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [400, 0]
    },
    {
      "parameters": {
        "jsCode": "// This node gets the file content from the previous node\n// AND retrieves the repo info from the box before that to keep it alive\nconst repoInfo = $(\"Parse_Request\").first().json;\nconst content = $input.all()[0].json.content;\n\nlet pkg = JSON.parse(content);\n\n// THE FIX: Add missing lodash\npkg.dependencies = pkg.dependencies || {};\npkg.dependencies.lodash = \"^4.17.21\";\n\nreturn {\n  fixed_content: JSON.stringify(pkg, null, 2),\n  owner: repoInfo.owner,\n  repo: repoInfo.repo,\n  path: repoInfo.path,\n  branch: repoInfo.branch\n};"
      },
      "id": "4",
      "name": "Analyze_and_Fix",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 0]
    },
    {
      "parameters": {
        "resource": "file",
        "operation": "edit",
        "owner": "={{$json.owner}}",
        "repository": "={{$json.repo}}",
        "filePath": "={{$json.path}}",
        "fileContent": "={{$json.fixed_content}}",
        "commitMessage": "Auto-heal: Fixed build failure by updating package.json",
        "branch": "={{$json.branch}}"
      },
      "id": "5",
      "name": "Push_Fix_to_GitHub",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [800, 0]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Parse_Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse_Request": {
      "main": [
        [
          {
            "node": "Get_Original_File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get_Original_File": {
      "main": [
        [
          {
            "node": "Analyze_and_Fix",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Analyze_and_Fix": {
      "main": [
        [
          {
            "node": "Push_Fix_to_GitHub",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
