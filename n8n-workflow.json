{
  "name": "Self-Healing-CI-HACKATHON-FINAL-FIX",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "self-heal",
        "options": {}
      },
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300],
      "webhookId": "self-heal-webhook"
    },
    {
      "parameters": {
        "resource": "file",
        "operation": "get",
        "owner": "={{$json.body.repository.split('/')[0]}}",
        "repository": "={{$json.body.repository.split('/')[1]}}",
        "filePath": "={{$json.body.file_to_fix}}",
        "reference": "={{$json.body.branch}}"
      },
      "id": "2",
      "name": "GitHub Get File",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "jsCode": "// This node takes the file content and the original webhook data\nconst fileData = $input.all()[0].json;\nconst webhookData = $(\"Webhook\").item.json.body;\n\nlet pkg = JSON.parse(fileData.content);\n\n// THE FIX: Add missing dependency\npkg.dependencies = pkg.dependencies || {};\npkg.dependencies.lodash = \"^4.17.21\";\n\nreturn {\n  fixed_content: JSON.stringify(pkg, null, 2),\n  owner: webhookData.repository.split('/')[0],\n  repo: webhookData.repository.split('/')[1],\n  path: webhookData.file_to_fix,\n  branch: webhookData.branch\n};"
      },
      "id": "3",
      "name": "Heal Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [500, 300]
    },
    {
      "parameters": {
        "resource": "file",
        "operation": "edit",
        "owner": "={{$json.owner}}",
        "repository": "={{$json.repo}}",
        "filePath": "={{$json.path}}",
        "fileContent": "={{$json.fixed_content}}",
        "commitMessage": "Auto-heal: Fixed build failure by updating package.json",
        "branch": "={{$json.branch}}"
      },
      "id": "4",
      "name": "GitHub Commit Fix",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [700, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "GitHub Get File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GitHub Get File": {
      "main": [
        [
          {
            "node": "Heal Logic",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Heal Logic": {
      "main": [
        [
          {
            "node": "GitHub Commit Fix",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
